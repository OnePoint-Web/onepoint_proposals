// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Accounts
model User {
  userId Int @id @default(autoincrement())
  username String @unique
  firstName String 
  lastName String
  userEmail String @unique
  userPassword String 
  accountStatus Int @default(1)
  accountRole Int
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  role Role @relation(fields: [accountRole], references: roleId)
  userStatus AccountStatus @relation(fields: [accountStatus], references: statusId) 

  proposals Proposal[]
  clientProfile ClientProfile?
  discoverySessions DiscoverySession[]
}

model AccountStatus {
  statusId Int @id @default(autoincrement())
  status String

  users User[]
}

model Role {
  roleId Int @id @default(autoincrement())
  role String

  users User[]
}

model ClientProfile {
  clientId Int @id @default(autoincrement())
  userId Int @unique
  companyName String
  companyEmail String?
  companyAddress String?
  website String?
  dateCreated DateTime @default(now())

  proposals Proposal[]
  user User @relation(fields: [userId], references: userId, onDelete: Cascade)

   @@index([userId])
}


// Proposals 
model Proposal {
  proposalId Int @id @default(autoincrement())
  slug String @unique
  clientId Int
  clientType String
  proposalTitle String //updated
  proposalType String
  executiveSummary String @db.LongText
  goalsAndObjectives String @db.LongText
  execVideoUrl String?
  proposedSolution String @db.LongText
  proposalDescription String? @db.LongText
  statusId Int
  createdBy Int
  statusUpdated DateTime @default(now()) //updated
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  //Addtional fields for proposal view tracking
  firstViewedAt DateTime?
  lastViewedAt DateTime?
  viewCount Int?


  // ______________

  clientProfile ClientProfile @relation(fields: [clientId], references: clientId)
  proposalStatus ProposalStatus @relation(fields: [statusId], references: statusId)
  user User @relation(fields: [createdBy], references: userId)

  slaOffers SlaOffer[]
  serviceProductOffers ServiceProductOffer[]
  proposalViews ProposalView[]
  selectedMembers SelectedMember[]
  timelines Timeline[]
  shareTokens ProposalShareToken[]
}

model ProposalStatus {
  statusId Int @id
  status String

  proposals Proposal[]
}

model ProposalView {
  viewId     Int      @id @default(autoincrement())
  proposalId Int
  clientId   Int?
  tokenId    Int?
  dateViewed DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: proposalId)
}

// Proposal sessions to track proposal view time
model ProposalSession {
  sessionId       Int       @id @default(autoincrement())
  proposalId      Int
  clientId        Int?
  tokenId         Int?
  startedAt       DateTime  @default(now())
  lastActivityAt  DateTime?
  endedAt         DateTime?
  durationSeconds Int?
}

model ProposalShareToken {
  tokenId        Int       @id @default(autoincrement())
  token          String    @unique
  proposalId     Int
  recipientEmail String
  isPortalUser   Boolean   @default(false)
  portalUserId   Int?
  usedAt         DateTime?
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  proposal Proposal @relation(fields: [proposalId], references: proposalId, onDelete: Cascade)
}

// Team Members
model SelectedMember {
  selectedMemberId Int @id @default(autoincrement())
  proposalId Int
  memberId Int

  proposal Proposal @relation(fields: [proposalId], references: proposalId, onDelete: Cascade)

  teamMember TeamMember @relation(fields: [memberId], references: memberId)
}

model TeamMember{
  memberId Int @id @default(autoincrement())
  memberName String
  memberRole String
  memberImage String
  description String
  isActive Boolean @default(true)
  deleted Boolean @default(false) //updated: add
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  selectedMembers SelectedMember[]
}

// Timelines
model Timeline {
  timelineId Int @id @default(autoincrement())
  proposalId Int
  timeFrame String
  progress Int
  assignedTo String?
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: proposalId, onDelete: Cascade)

  timelineScopeItems TimelineScopeItem[]
}

model TimelineScopeItem {
  scopeItemId Int @id @default(autoincrement())
  timelineId Int
  scope String

  timeline Timeline @relation(fields: [timelineId], references: timelineId, onDelete: Cascade)
}

// SLA Offers

model SlaOffer {
  slaOfferId Int @id @default(autoincrement())
  proposalId Int
  slaPackage String
  basePrice Decimal @db.Decimal(10, 2)
  discountType String
  discountValue Decimal? @db.Decimal(10, 2)
  discountDescription String?
  taxableAmount Decimal @db.Decimal(10, 2)
  taxApplicable Boolean
  taxRate Decimal @db.Decimal(10, 2)
  taxAmount Decimal @db.Decimal(10, 2)
  taxReason String
  finalPrice Decimal @db.Decimal(10, 2)
  paymentTerms String @db.LongText
  dateCreate DateTime @default(now())

  packageDealItem PackageDealItem[]

  proposal Proposal @relation(fields: [proposalId], references: proposalId, onDelete: Cascade)
}

model Package{
  packageId Int @id @default(autoincrement())
  slug String @unique
  package String @unique
  description String @db.LongText
  proposedSolution String? @db.LongText
  basePrice Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  dealItems DealItem[]
}

model DealItem {
  dealItemId Int @id @default(autoincrement())
  packageId Int
  dealItem String
  itemType String
  displayOrder Int
  dateCreated DateTime @default(now())

  dealEntries DealEntry[]

  package Package @relation(fields: [packageId], references: packageId, onDelete: Cascade)
}

model DealEntry{
  itemEntryId Int @id @default(autoincrement())
  dealItemId Int
  itemEntry String
  displayOrder Int
  dateCreated DateTime @default(now())

  dealItem DealItem @relation(fields: [dealItemId], references: dealItemId, onDelete: Cascade)
}

model PackageDealItem {
  packageDealItemId Int @id @default(autoincrement())
  slaOfferId Int
  isCustom Boolean @default(false)
  item String
  itemType String
  displayOrder Int
  dateCreated DateTime @default(now())

  slaOffer SlaOffer @relation(fields: [slaOfferId], references: slaOfferId, onDelete: Cascade)
  
  packageDealEntries PackageDealEntry[]
}

model PackageDealEntry{
  itemEntryId Int @id @default(autoincrement())
  packageDealItemId Int
  itemEntry String
  displayOrder Int
  dateCreated DateTime @default(now())

  packageDealItem PackageDealItem @relation(fields: [packageDealItemId], references: [packageDealItemId], onDelete: Cascade)
}

// Service Product offers

model ServiceProductOffer {
  serviceProductOfferId Int @id @default(autoincrement())
  proposalId Int
  type String
  isMultipleChoice Boolean @default(false)
  subTotal Decimal @db.Decimal(10, 2)
  discountType String
  discountValue Decimal? @db.Decimal(10, 2)
  discountDescription String? 
  taxableAmount Decimal @db.Decimal(10, 2)
  taxApplicable Boolean //updated
  taxRate Decimal? @db.Decimal(10, 2)
  taxAmount Decimal? @db.Decimal(10, 2)
  taxReason String?
  finalPrice Decimal @db.Decimal(10, 2)
  paymentTerms String @db.LongText
  dateCreated DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: proposalId, onDelete: Cascade)

  offerEntries OfferEntry[]
}

model Service {
  serviceId Int @id @default(autoincrement())
  service String
  price Decimal @db.Decimal(10, 2)
  description String? @db.LongText
  dateCreated DateTime @default(now())
  dataUpdated DateTime? @updatedAt 
}

model Product {
  productId Int @id @default(autoincrement())
  product String
  productImage String?
  price Decimal @db.Decimal(10, 2)
  description String? @db.LongText
  dateCreated DateTime @default(now())
  dataUpdated DateTime? @updatedAt 
}

model OfferEntry {
  offerEntryId Int @id @default(autoincrement())
  serviceProductOfferId Int
  serviceProductItem String
  itemImage String?
  itemPrice Decimal @db.Decimal(10, 2)
  quantity Int
  totalPrice Decimal @db.Decimal(10, 2)
  itemDiscountType String?
  itemDiscountValue Decimal? @db.Decimal(10, 2)
  itemDiscountDescription String?
  description String?
  displayOrder Int
  isSelected Boolean @default(true)
  dateCreated DateTime @default(now())

  serviceProductOffer ServiceProductOffer @relation(fields: [serviceProductOfferId], references: serviceProductOfferId, onDelete: Cascade)
}

model Media {
  mediaId Int @id @default(autoincrement())

  fileName String
  originalName String

  bucketKey String

  mimeType String
  fileSize Int

  uploadedBy Int?

  createdAt DateTime @default(now())
}

