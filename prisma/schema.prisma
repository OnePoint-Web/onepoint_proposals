// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


model User {
   userId Int @id @default(autoincrement())
   username String @unique
   firstName String 
   lastName String
   userEmail String @unique
   userPassword String 
   accountStatus String
   accountRole String
   dateCreated DateTime @default(now())
   dateUpdated DateTime? @updatedAt

   clientProfiles ClientProfile[]
}

model ClientProfile {
  clientId Int @id @default(autoincrement())
  userId Int
  companyName String
  companyEmail String?
  companyAddress String?
  website String?
  dateCreated DateTime @default(now())

  proposals Proposal[]
  user User @relation(fields: [userId], references: userId, onDelete: Cascade)

   @@index([userId])
}

model Proposal {
  proposalId Int @id @default(autoincrement())
  clientId Int
  clientType String
  proposalTitle String @unique
  proposalType String
  executiveSummary String @db.LongText
  goalsAndObjectives String @db.LongText
  proposedSolution String @db.LongText
  statusId Int
  createdBy Int
  statusUpdated DateTime
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  clientProfile ClientProfile @relation(fields: [clientId], references: clientId)
  proposalStatus ProposalStatus @relation(fields: [statusId], references: statusId)
  user User @relation(fields: [createdBy], references: userId)

  slaOffers SlaOffer[]

}

model ProposalStatus {
  statusId Int @id @default(autoincrement())
  status String

  proposals Proposal[]
}

// SLA Offers

model SlaOffer {
  slaOfferId Int @id @default(autoincrement())
  proposalId Int
  selectedPackageId Int
  basePrice Decimal @db.Decimal(10, 2)
  discountType String
  discountValue Decimal? @db.Decimal(10, 2)
  discountDescription String?
  taxableAmount Decimal @db.Decimal(10, 2)
  taxApplicable Boolean
  taxRate Decimal @db.Decimal(10, 2)
  taxAmount Decimal @db.Decimal(10, 2)
  taxReason String
  finalPrice Decimal @db.Decimal(10, 2)
  paymentTerms String
  dateCreate DateTime @default(now())

  packageDealItem PackageDealItem[]

  proposal Proposal @relation(fields: [proposalId], references: proposalId)
  package Package @relation(fields: [selectedPackageId], references: packageId)
}

model Package{
  packageId Int @id @default(autoincrement())
  package String @unique
  description String
  proposedSolution String @db.LongText
  basePrice Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  slaOffers SlaOffer[]
  dealItems DealItem[]
  packageDealItem PackageDealItem[]
}

model DealItem {
  dealItemId Int @id @default(autoincrement())
  packageId Int
  dealItem String
  itemType String
  dateCreated DateTime @default(now())

  dealEntries DealEntry[]

  package Package @relation(fields: [packageId], references: packageId)
}

model DealEntry{
  itemEntryId Int @id @default(autoincrement())
  dealItemId Int
  itemEntry String
  displayOrder Int
  dateCreated DateTime @default(now())

  dealItem DealItem @relation(fields: [dealItemId], references: dealItemId)
}

model PackageDealItem {
  dealItemId Int @id @default(autoincrement())
  slaOfferId Int
  packageDealItemId Int 
  isCustom Boolean @default(false)
  item String
  itemType String
  displayOrder Int
  dateCreated DateTime @default(now())

  slaOffer SlaOffer @relation(fields: [slaOfferId], references: slaOfferId)
  dealItem DealItem @relation(fields: [packageDealItemId], references: dealItemId)
}

model PackageDealEntry{
  itemEntryId Int @id @default(autoincrement())
  dealItemId Int
  itemEntry String
  displayOrder Int
  dateCreated DateTime @default(now())

  packageDealItem PackageDealItem @relation(fields: [dealItemId], references: [dealItemId])
}

// Service Product offers

model ServiceProductOffer {
  serviceProductOfferId Int @id @default(autoincrement())
  proposalId Int
  description String
  type String
  isMultipleChoice Boolean @default(false)
  subTotal Decimal @db.Decimal(10, 2)
}