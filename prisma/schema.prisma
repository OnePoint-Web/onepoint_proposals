// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// Accounts
model User {
  userId Int @id @default(autoincrement())
  username String @unique
  firstName String 
  lastName String
  userEmail String @unique
  userPassword String 
  accountStatus String
  accountRole Int
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  role Role @relation(fields: [accountRole], references: roleId)

  proposals Proposal[]
  clientProfiles ClientProfile[]
}

model Role {
  roleId Int @id @default(autoincrement())
  role String

  users User[]
}

model ClientProfile {
  clientId Int @id @default(autoincrement())
  userId Int
  companyName String
  companyEmail String?
  companyAddress String?
  website String?
  dateCreated DateTime @default(now())

  proposals Proposal[]
  user User @relation(fields: [userId], references: userId, onDelete: Cascade)

   @@index([userId])
}


// Proposals 
model Proposal {
  proposalId Int @id @default(autoincrement())
  clientId Int
  clientType String
  proposalTitle String @unique
  proposalType String
  executiveSummary String @db.LongText
  goalsAndObjectives String @db.LongText
  proposedSolution String @db.LongText
  statusId Int
  createdBy Int
  statusUpdated DateTime
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  clientProfile ClientProfile @relation(fields: [clientId], references: clientId)
  proposalStatus ProposalStatus @relation(fields: [statusId], references: statusId)
  user User @relation(fields: [createdBy], references: userId)

  slaOffers SlaOffer[]
  serviceProductOffers ServiceProductOffer[]
  proposalViews ProposalView[]
  selectedMembers SelectedMember[]
  timlines Timeline[]
}

model ProposalStatus {
  statusId Int @id @default(autoincrement())
  status String

  proposals Proposal[]
}

model ProposalView {
  viewId Int @id @default(autoincrement())
  proposalId Int
  clientId Int
  dateViewed DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: proposalId)
}

// Team Members
model SelectedMember {
  selectedMemberId Int @id @default(autoincrement())
  proposalId Int
  memberId Int

  proposal Proposal @relation(fields: [proposalId], references: proposalId)

  teamMember TeamMember @relation(fields: [memberId], references: memberId)
}

model TeamMember{
  memberId Int @id @default(autoincrement())
  memberName String
  memberRole String
  memberImage String
  description String
  isActive Boolean @default(true)
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  selectedMembers SelectedMember[]
}

// Timelines
model Timeline {
  timelineId Int @id @default(autoincrement())
  proposalId Int
  timeFrame String
  progress Int
  assignedTo String?
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  proposal Proposal @relation(fields: [proposalId], references: proposalId)

  timelineScopeItems TimelineScopeItem[]
}

model TimelineScopeItem {
  scopeItemId Int @id @default(autoincrement())
  timelineId Int
  scope String

  timeline Timeline @relation(fields: [timelineId], references: timelineId)
}

// SLA Offers

model SlaOffer {
  slaOfferId Int @id @default(autoincrement())
  proposalId Int
  selectedPackageId Int
  basePrice Decimal @db.Decimal(10, 2)
  discountType String
  discountValue Decimal? @db.Decimal(10, 2)
  discountDescription String?
  taxableAmount Decimal @db.Decimal(10, 2)
  taxApplicable Boolean
  taxRate Decimal @db.Decimal(10, 2)
  taxAmount Decimal @db.Decimal(10, 2)
  taxReason String
  finalPrice Decimal @db.Decimal(10, 2)
  paymentTerms String
  dateCreate DateTime @default(now())

  packageDealItem PackageDealItem[]

  proposal Proposal @relation(fields: [proposalId], references: proposalId)
  package Package @relation(fields: [selectedPackageId], references: packageId)
}

model Package{
  packageId Int @id @default(autoincrement())
  package String @unique
  description String
  proposedSolution String @db.LongText
  basePrice Decimal @db.Decimal(10, 2)
  isActive Boolean @default(true)
  dateCreated DateTime @default(now())
  dateUpdated DateTime? @updatedAt

  slaOffers SlaOffer[]
  dealItems DealItem[]
}

model DealItem {
  dealItemId Int @id @default(autoincrement())
  packageId Int
  dealItem String
  itemType String
  dateCreated DateTime @default(now())

  dealEntries DealEntry[]

  package Package @relation(fields: [packageId], references: packageId)
}

model DealEntry{
  itemEntryId Int @id @default(autoincrement())
  dealItemId Int
  itemEntry String
  displayOrder Int
  dateCreated DateTime @default(now())

  dealItem DealItem @relation(fields: [dealItemId], references: dealItemId)
}

model PackageDealItem {
  packageDealItemId Int @id @default(autoincrement())
  slaOfferId Int
  isCustom Boolean @default(false)
  item String
  itemType String
  displayOrder Int
  dateCreated DateTime @default(now())

  slaOffer SlaOffer @relation(fields: [slaOfferId], references: slaOfferId)
  
  packageDealEntries PackageDealEntry[]
}

model PackageDealEntry{
  itemEntryId Int @id @default(autoincrement())
  packageDealItemId Int
  itemEntry String
  displayOrder Int
  dateCreated DateTime @default(now())

  packageDealItem PackageDealItem @relation(fields: [packageDealItemId], references: [packageDealItemId])
}

// Service Product offers

model ServiceProductOffer {
  serviceProductOfferId Int @id @default(autoincrement())
  proposalId Int
  description String
  type String
  isMultipleChoice Boolean @default(false)
  subTotal Decimal @db.Decimal(10, 2)
  discountType String
  discountValue Decimal? @db.Decimal(10, 2)
  discountDescription String? 
  taxableAmount Decimal @db.Decimal(10, 2)
  taxApplicable Decimal @db.Decimal(10, 2)
  taxRate Decimal? @db.Decimal(10, 2)
  taxAmount Decimal? @db.Decimal(10, 2)
  taxReason String?
  finalPrice Decimal @db.Decimal(10, 2)
  paymentTerms String
  dateCreated DateTime @default(now())

  proposal Proposal @relation(fields: [proposalId], references: proposalId)

  offerEntries OfferEntry[]
}

model OfferEntry {
  offerEntryId Int @id @default(autoincrement())
  serviceProductOfferId Int
  serviceProductItem String
  itemImage String?
  itemPrice Decimal @db.Decimal(10, 2)
  quantity Int
  totalPrice Decimal @db.Decimal(10, 2)
  itemDiscountType String?
  itemDiscountValue Decimal? @db.Decimal(10, 2)
  itemDiscountDescription String?
  description String?
  displayOrder Int
  dateCreated DateTime @default(now())

  serviceProductOffer ServiceProductOffer @relation(fields: [serviceProductOfferId], references: serviceProductOfferId)
}

// Notifications
model Notification{
  notificationId Int @id @default(autoincrement())
  userId Int
  title String
  message String
  entityType String 
  entityId Int
  notificationType String
  isRead Boolean @default(false)
  createdAt DateTime @default(now())
}

model ActivityLogs{
  activityId Int @id @default(autoincrement())
  entityType String 
  entityId Int
  action String
  performedBy Int
  performedByRole String
  metaData Json?
  createdAt DateTime @default(now())

}

model NotificationRules{
  ruleId Int @id @default(autoincrement())
  eventAction String
  entityType String
  notifyRole String
  isActive Boolean @default(true)
}